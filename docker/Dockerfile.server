FROM python:3.12-slim

WORKDIR /app

# System dependencies (ADB)
RUN apt-get update -qq && apt-get install -y \
    adb curl wget \
    && rm -rf /var/lib/apt/lists/*

# Python dependencies
COPY server/requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

# Application code
COPY server/ ./server/

# Data directory
RUN mkdir -p /data

EXPOSE 8384 7384

CMD ["python", "-m", "uvicorn", "server.brain.brain_api:app", "--host", "0.0.0.0", "--port", "8384"]
